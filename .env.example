# Better Auth — secret key for signing session cookies (generate with `openssl rand -hex 32`)
BETTER_AUTH_SECRET=""
# Better Auth — base URL for the app (set to your Vercel URL in production, e.g. https://zara-perfumes.vercel.app)
BETTER_AUTH_URL=""
# GitHub OAuth provider — client ID from your GitHub OAuth App
BETTER_AUTH_GITHUB_CLIENT_ID=""
# GitHub OAuth provider — client secret from your GitHub OAuth App
BETTER_AUTH_GITHUB_CLIENT_SECRET=""
# Google OAuth provider — client ID from your Google Cloud Console OAuth 2.0 credentials
BETTER_AUTH_GOOGLE_CLIENT_ID=""
# Google OAuth provider — client secret from your Google Cloud Console OAuth 2.0 credentials
BETTER_AUTH_GOOGLE_CLIENT_SECRET=""

# Stripe — secret key for server-side Stripe API calls (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=""
# Stripe — webhook signing secret for verifying incoming webhook event payloads
STRIPE_WEBHOOK_SECRET=""
# Stripe — publishable key exposed to the browser for Stripe Checkout (starts with pk_live_ or pk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Drizzle / PostgreSQL — full connection string for the PostgreSQL database
DATABASE_URL="postgresql://postgres:password@localhost:5432/zara"
