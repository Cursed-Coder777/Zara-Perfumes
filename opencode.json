{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode",
    "opencode-skills",
    "opencode-websearch-cited@1.2.0",
    "micode"
  ],
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["pnpm", "dlx", "shadcn@latest", "mcp"]
    },
    "tailwindcss": {
      "type": "local",
      "command": ["pnpm", "dlx", "tailwindcss-mcp-server"]
    },
    "eslint-mcp": {
      "type": "local",
      "command": ["pnpm", "dlx", "eslint-mcp-server"]
    },
    "cog-mcp": {
      "type": "local",
      "command": ["cog-mcp", "--path", "/home/coder/Zara-Perfumes"]
    }
  },
  "provider": {
    "google": {
      "options": {
        "websearch_cited": {
          "model": "gemini-2.5-flash"
        }
      }
    }
  },
  "skills": {
    "paths": [".opencode/skills"]
  }
}
